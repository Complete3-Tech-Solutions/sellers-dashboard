# Copy to .env and fill in. .env is gitignored. Used by docker-compose (db + app).
# Generate secrets:
#   Fernet : python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
#   JWT    : openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#            openssl rsa -pubout -in jwt_private.pem -out jwt_public.pem
#            (then collapse each PEM to one line with literal \n between the lines)
#   Passwd : openssl rand -base64 24

ENV=prod

# --- Postgres (compose db service reads these; DATABASE_URL must use the same pw) ---
POSTGRES_USER=scc
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=scc
DATABASE_URL=postgresql+asyncpg://scc:CHANGE_ME_DB_PASSWORD@db:5432/scc

# --- Redis (compose service name) ---
REDIS_URL=redis://redis:6379/0

# --- Crypto (paste full PEM as a single line, real newlines replaced by \n) ---
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
KMS_FERNET_KEY=CHANGE_ME_FERNET_KEY

# --- Cookies / CORS ---
# COOKIE_SECURE=true requires users to reach the app over HTTPS (proxy terminates TLS).
# If your proxy serves plain HTTP, set this to false or login cookies won't persist.
COOKIE_DOMAIN=
COOKIE_SECURE=true
# The PUBLIC origin users hit (scheme + host), comma-separated. NOT localhost.
ALLOWED_ORIGINS=https://dashboard.example.com

# --- First admin login (single-tenant bootstrap) ---
AUTO_SEED_ADMIN=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
# Optional second member user (both required to create it):
# USER_EMAIL=member@example.com
# USER_PASSWORD=CHANGE_ME_USER_PASSWORD

# PARSER_INLINE defaults to true (inline parsing, no separate worker). Leave unset.

# --- Optional integrations (leave blank if unused) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scc-saas-snapshots
R2_ENDPOINT_URL=
SENTRY_DSN_BACKEND=
POSTMARK_SERVER_TOKEN=
